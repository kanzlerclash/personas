{
  "name": "kanzlerclash-personas",
  "version": "0.1.0",
  "private": true,
  "description": "Forschungsdaten: LLM-Vergleich fiktiver Personas mit den Wahlprogrammen zur LTW 2026 (Sachsen-Anhalt, Mecklenburg-Vorpommern, Berlin).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cache": "tsx src/pipeline/cache-programme.ts",
    "vergleich": "tsx src/pipeline/vergleich.ts",
    "verify": "tsx src/pipeline/verify-belege.ts",
    "bevoelkerung": "tsx src/pipeline/bevoelkerung.ts",
    "site:data": "tsx src/site/build-data.ts",
    "build": "tsx src/ssg/build.ts",
    "preview": "PAGES_BASE=/ tsx src/ssg/build.ts && python3 -m http.server --directory dist 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-antlitz-kartei/generator": "^0.3.0",
    "ai": "^5.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "canvas": "^3.2.3",
    "pdfjs-dist": "^4.7.76",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
